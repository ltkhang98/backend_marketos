# ==========================================
# HƯỚNG DẪN THIẾT LẬP BIẾN MÔI TRƯỜNG
# Copy file này, đổi tên thành .env và điền các giá trị
# ==========================================

# --- Gemini AI ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Firebase Admin SDK (BẮT BUỘC cho Vercel) ---
# Lấy từ file firebase-adminsdk.json tương ứng
FIREBASE_PROJECT_ID=marketos-9b845
FIREBASE_PRIVATE_KEY_ID=your_private_key_id
# Lưu ý: Khi nhập vào Vercel, paste nguyên đoạn key (gồm cả -----BEGIN PRIVATE KEY-----)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@marketos-9b845.iam.gserviceaccount.com
FIREBASE_STORAGE_BUCKET=marketos-9b845.firebasestorage.app

# --- SePay ---
SEPAY_MERCHANT_ID=your_sepay_merchant_id
SEPAY_API_KEY=your_sepay_api_key

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=MarketOS <your_email@gmail.com>

# --- FPT AI (Text to Speech) ---
FPT_AI_API_KEY=your_fpt_ai_key

# --- Server ---
PORT=3000
